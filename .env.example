# ── LLM Provider ──────────────────────────────────────────────
GROQ_API_KEY=gsk_your_key_here
LLM_MODEL=llama-3.3-70b-versatile
LLM_TEMPERATURE=0

# ── MySQL ─────────────────────────────────────────────────────
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=mpay_ai
MYSQL_PASSWORD=mpay_ai_password
MYSQL_DATABASE=mpay_dev

# ── Agent behaviour ──────────────────────────────────────────
AUTO_EXECUTE=false
LOG_LEVEL=INFO
